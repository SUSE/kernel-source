+++ b/kernel/cpu.c
@@ -814,6 +814,12 @@ static void cpuhp_online_cpu_device(unsi
 	kobject_uevent(&sys_dev->kobj, KOBJ_ONLINE);
 }
 
+/*
+ * Architectures that need SMT-specific errata handling during SMT hotplug
