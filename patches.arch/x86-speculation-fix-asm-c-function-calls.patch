From: Jiri Bohac <jbohac@suse.cz>
Subject: x86/speculation/mds: fix asm to C function calls
Patch-mainline: no, suse specific
References: bsc#1111331, CVE-2018-12126, CVE-2018-12127, CVE-2018-12130, CVE-2019-11091

The call of mds_clear_user in entry did not properly restore clobbered registers.

Calling C from the asm entry code safely would require pushing and restoring a lot of
registers; convert x86_ibrs_enabled and mds_clear_user to assembly instead.

---
 arch/x86/include/asm/spec_ctrl.h    |    6 +++---
 arch/x86/kernel/cpu/Makefile        |    1 +
 arch/x86/kernel/cpu/spec_ctrl.c     |    5 -----
 arch/x86/kernel/cpu/spec_ctrl_asm.S |   35 +++++++++++++++++++++++++++++++++++
 4 files changed, 39 insertions(+), 8 deletions(-)

--- a/arch/x86/include/asm/spec_ctrl.h
+++ b/arch/x86/include/asm/spec_ctrl.h
@@ -16,7 +16,7 @@
 .endm
 
 .macro ENABLE_IBRS_CLOBBER
-	call x86_ibrs_enabled
+	call x86_ibrs_enabled_asm
 	test %eax, %eax
 	jz .Llfence_\@
 
@@ -33,7 +33,7 @@
 
 	pushq %rax
 
-	call x86_ibrs_enabled
+	call x86_ibrs_enabled_asm
 	test %eax, %eax
 	jz .Llfence_\@
 
@@ -59,7 +59,7 @@
 
 	pushq %rax
 
-	call x86_ibrs_enabled
+	call x86_ibrs_enabled_asm
 	test %eax, %eax
 	jz .Llfence_\@
 
--- a/arch/x86/kernel/cpu/Makefile
+++ b/arch/x86/kernel/cpu/Makefile
@@ -18,6 +18,7 @@ obj-y			+= vmware.o hypervisor.o sched.o
 obj-y			+= rdrand.o
 obj-y			+= match.o
 obj-y			+= spec_ctrl.o
+obj-$(CONFIG_X86_64)	+= spec_ctrl_asm.o
 obj-y			+= bugs.o
 
 obj-$(CONFIG_CPU_SUP_INTEL)		+= intel.o
--- a/arch/x86/kernel/cpu/spec_ctrl.c
+++ b/arch/x86/kernel/cpu/spec_ctrl.c
@@ -132,8 +132,3 @@ int __init nospec(char *str)
 }
 early_param("nospec", nospec);
 
-/* Wrapper callable by asm */
-void mds_clear_user(void)
-{
-	return mds_user_clear_cpu_buffers();
-}
--- /dev/null
+++ b/arch/x86/kernel/cpu/spec_ctrl_asm.S
@@ -0,0 +1,35 @@
+#include <asm/segment.h>
+
+	.text
+	
+	.globl	x86_ibrs_enabled_asm
+	.type	x86_ibrs_enabled_asm, @function
+x86_ibrs_enabled_asm:
+	xorl	%eax, %eax
+	cmpl	$1, ibrs_state(%rip)
+	sete	%al
+	ret
+	
+	.size	x86_ibrs_enabled_asm, .-x86_ibrs_enabled_asm
+
+
+
+	.globl	mds_clear_user
+	.type	mds_clear_user, @function
+mds_clear_user:
+	cmpb	$0, mds_user_clear(%rip)
+	je	1f
+	verw 	ds(%rip)
+1:
+	ret
+	
+	.size	mds_clear_user, .-mds_clear_user
+	
+
+	.section	.rodata
+	.align 2
+	.type	ds.1 @object
+	.size	ds.1, 2
+ds:
+	.value	__KERNEL_DS
+	
