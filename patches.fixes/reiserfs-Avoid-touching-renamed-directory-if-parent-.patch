From 49db9b1b86a82448dfaf3fcfefcf678dee56c8ed Mon Sep 17 00:00:00 2001
From: Jan Kara <jack@suse.cz>
Date: Thu, 12 Oct 2023 23:14:20 +0200
Subject: [PATCH] reiserfs: Avoid touching renamed directory if parent does not
 change
Git-commit: 49db9b1b86a82448dfaf3fcfefcf678dee56c8ed
Patch-mainline: v6.8-rc1
References: git-fixes bsc#1221044 CVE-2023-52591

The VFS will not be locking moved directory if its parent does not
change. Change reiserfs rename code to avoid touching renamed directory
if its parent does not change as without locking that can corrupt the
filesystem.

Signed-off-by: Jan Kara <jack@suse.cz>
Signed-off-by: Al Viro <viro@zeniv.linux.org.uk>
Acked-by: Anthony Iliopoulos <ailiop@suse.com>

---
 fs/reiserfs/namei.c |   57 ++++++++++++++++++++++++++++------------------------
 1 file changed, 31 insertions(+), 26 deletions(-)

--- a/fs/reiserfs/namei.c
+++ b/fs/reiserfs/namei.c
@@ -1225,9 +1225,9 @@ static int reiserfs_rename(struct inode
 	struct inode *old_inode, *new_dentry_inode;
 	struct reiserfs_transaction_handle th;
 	int jbegin_count;
-	umode_t old_inode_mode;
 	unsigned long savelink = 1;
 	struct timespec ctime;
+	bool update_dir_parent = false;
 
 	/* three balancings: (1) old name removal, (2) new name insertion
 	   and (3) maybe "save" link insertion
@@ -1266,8 +1266,7 @@ static int reiserfs_rename(struct inode
 		return -ENOENT;
 	}
 
-	old_inode_mode = old_inode->i_mode;
-	if (S_ISDIR(old_inode_mode)) {
+	if (S_ISDIR(old_inode->i_mode)) {
 		// make sure, that directory being renamed has correct ".."
 		// and that its new parent directory has not too many links
 		// already
@@ -1279,24 +1278,29 @@ static int reiserfs_rename(struct inode
 			}
 		}
 
-		/* directory is renamed, its parent directory will be changed,
-		 ** so find ".." entry
-		 */
-		dot_dot_de.de_gen_number_bit_string = NULL;
-		retval =
-		    reiserfs_find_entry(old_inode, "..", 2, &dot_dot_entry_path,
-					&dot_dot_de);
-		pathrelse(&dot_dot_entry_path);
-		if (retval != NAME_FOUND ||
-		    dot_dot_de.de_objectid != old_dir->i_ino) {
-			reiserfs_write_unlock(old_dir->i_sb);
-			return -EIO;
-		}
+		if (old_dir != new_dir) {
+			/* directory is renamed, its parent directory will be
+			 * changed, so find ".." entry
+			 */
+			dot_dot_de.de_gen_number_bit_string = NULL;
+			retval =
+			    reiserfs_find_entry(old_inode, "..", 2,
+						&dot_dot_entry_path,
+						&dot_dot_de);
+			pathrelse(&dot_dot_entry_path);
 
-		/* inode number of .. must equal old_dir->i_ino */
-		if (dot_dot_de.de_objectid != old_dir->i_ino) {
-			reiserfs_write_unlock(old_dir->i_sb);
-			return -EIO;
+			if (retval != NAME_FOUND ||
+			    dot_dot_de.de_objectid != old_dir->i_ino) {
+				reiserfs_write_unlock(old_dir->i_sb);
+				return -EIO;
+			}
+
+			/* inode number of .. must equal old_dir->i_ino */
+			if (dot_dot_de.de_objectid != old_dir->i_ino) {
+				reiserfs_write_unlock(old_dir->i_sb);
+				return -EIO;
+			}
+			update_dir_parent = true;
 		}
 	}
 
@@ -1395,7 +1399,7 @@ static int reiserfs_rename(struct inode
 
 		reiserfs_prepare_for_journal(old_inode->i_sb, new_de.de_bh, 1);
 
-		if (S_ISDIR(old_inode->i_mode)) {
+		if (update_dir_parent) {
 			if ((retval =
 			     search_by_entry_key(new_dir->i_sb,
 						 &dot_dot_de.de_entry_key,
@@ -1451,7 +1455,7 @@ static int reiserfs_rename(struct inode
 		if (retval != 1)
 			goto restore;
 
-		if (S_ISDIR(old_inode_mode)) {
+		if (update_dir_parent) {
 			if (item_moved(&dot_dot_ih, &dot_dot_entry_path)) {
 				retval = 0;
 				goto restore;
@@ -1465,7 +1469,7 @@ static int reiserfs_rename(struct inode
 
 		retval = 0;
 
-		RFALSE(S_ISDIR(old_inode_mode) &&
+		RFALSE(update_dir_parent &&
 		       !buffer_journal_prepared(dot_dot_de.de_bh), "");
 
 		break;
@@ -1475,7 +1479,7 @@ restore:
 						 new_de.de_bh);
 		reiserfs_restore_prepared_buffer(old_inode->i_sb,
 						 old_de.de_bh);
-		if (S_ISDIR(old_inode_mode))
+		if (update_dir_parent)
 			reiserfs_restore_prepared_buffer(old_inode->i_sb,
 							 dot_dot_de.de_bh);
 		if (retval) {
@@ -1515,11 +1519,12 @@ restore:
 		savelink = new_dentry_inode->i_nlink;
 	}
 
-	if (S_ISDIR(old_inode_mode)) {
+	if (update_dir_parent) {
 		/* adjust ".." of renamed directory */
 		set_ino_in_dir_entry(&dot_dot_de, INODE_PKEY(new_dir));
 		journal_mark_dirty(&th, new_dir->i_sb, dot_dot_de.de_bh);
-
+	}
+	if (S_ISDIR(old_inode->i_mode)) {
 		if (!new_dentry_inode)
 			/* there (in new_dir) was no directory, so it got new link
 			   (".."  of renamed directory) */
