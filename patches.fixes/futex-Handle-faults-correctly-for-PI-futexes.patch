From: Davidlohr Bueso <dbueso@suse.de>
Date: Mon, 8 Feb 2021 19:37:28 -0800
Subject: [PATCH] futex: Handle faults correctly for PI futexes
Patch-mainline: Never, SLE specific fix
References: bsc#1181349 CVE-2021-3347

This is an alternative to the upstream fix:

     34b1a1ce145 (futex: Handle faults correctly for PI futexes)

Instead this approach relies on waiting when the victim task finds
itself unable to fault expecting for the issue to be fixed up
for us. It converts the fixup_pi_state_owner() to do an EAGAIN loop,
such that we don't leave the kernel state inconsistent, and just
wait that we either take the lock (in which the state is correct), or
someone else fixes the pi_state->owner for us.

Note that this was an approach tglx didn't want to take (at least for
upstream) because it could lead to runaway tasks. But these are
extraordinary circumstances in which the user is already doomed to
begin with if using pi futex locking on a RO mapping. Furthermore,
this is due to either malice or a programming mistake from the user,
either of which isn't particularly relevant for legacy releases.

Signed-off-by: Davidlohr Bueso <dbueso@suse.de>

---
 kernel/futex.c | 97 ++++++++++++++++++++++++++++++++------------------
 1 file changed, 62 insertions(+), 35 deletions(-)

diff --git a/kernel/futex.c b/kernel/futex.c
index 8d01703078ca..096c035c8193 100644
--- a/kernel/futex.c
+++ b/kernel/futex.c
@@ -1678,17 +1678,15 @@ static void unqueue_me_pi(struct futex_q *q)
  * private futexes.
  */
 static int fixup_pi_state_owner(u32 __user *uaddr, struct futex_q *q,
-				struct task_struct *newowner)
+				struct task_struct *argowner)
 {
-	u32 newtid = task_pid_vnr(newowner) | FUTEX_WAITERS;
+	u32 newtid;
 	struct futex_pi_state *pi_state = q->pi_state;
-	struct task_struct *oldowner = pi_state->owner;
+	struct task_struct *newowner, *oldowner;
 	u32 uval, curval, newval;
 	int ret;
 
-	/* Owner died? */
-	if (!pi_state->owner)
-		newtid |= FUTEX_OWNER_DIED;
+	oldowner = pi_state->owner;
 
 	/*
 	 * We are here either because we stole the rtmutex from the
@@ -1708,14 +1706,47 @@ static int fixup_pi_state_owner(u32 __user *uaddr, struct futex_q *q,
 	 * in lookup_pi_state.
 	 */
 retry:
+	if (!argowner) { /* the lock was stolen from us. */
+		if (rt_mutex_trylock(&q->pi_state->pi_mutex))
+			return 1;
+
+		/*
+		 * The trylock just failed, so either there is an owner or
+		 * there is a higher priority waiter than this one.
+		 */
+		raw_spin_lock(&q->pi_state->pi_mutex.wait_lock);
+		newowner = rt_mutex_owner(&q->pi_state->pi_mutex);
+		raw_spin_unlock(&q->pi_state->pi_mutex.wait_lock);
+
+		/*
+		 * If the higher priority waiter has not yet taken over the
+		 * rtmutex then newowner is NULL. We can't return here with
+		 * that state because it's inconsistent vs. the user space
+		 * state. So drop the locks and try again. It's a valid
+		 * situation and not any different from the other retry
+		 * conditions.
+		 */
+		if (!newowner) {
+			ret = -EAGAIN;
+			goto handle_err;
+		}
+	} else {
+		newowner = argowner; /* newowner == current */
+	}
+
+	newtid = task_pid_vnr(newowner) | FUTEX_WAITERS;
+	/* Owner died? */
+	if (!pi_state->owner)
+		newtid |= FUTEX_OWNER_DIED;
+
 	if (get_futex_value_locked(&uval, uaddr))
-		goto handle_fault;
+		goto handle_err;
 
 	while (1) {
 		newval = (uval & FUTEX_OWNER_DIED) | newtid;
 
 		if (cmpxchg_futex_value_locked(&curval, uaddr, uval, newval))
-			goto handle_fault;
+			goto handle_err;
 		if (curval == uval)
 			break;
 		uval = curval;
@@ -1750,10 +1781,14 @@ retry:
 	 * do another fixup. When the fixup has been done already we
 	 * simply return.
 	 */
-handle_fault:
+handle_err:
 	spin_unlock(q->lock_ptr);
 
-	ret = fault_in_user_writeable(uaddr);
+	if (ret == -EAGAIN) {
+		cond_resched();
+		ret = 0;
+	} else
+		ret = fault_in_user_writeable(uaddr);
 
 	spin_lock(q->lock_ptr);
 
@@ -1763,10 +1798,23 @@ handle_fault:
 	if (pi_state->owner != oldowner)
 		return 0;
 
-	if (ret)
-		return ret;
+	/*
+	 * Failed to fault, pi_state remains inconsistent with the pi_mutex.
+	 * If we're the lock stealer, we're done as the lock will be dropped.
+	 *
+	 * If we aren't the lock stealer, wait and retry until either the
+	 * stealer or any waiters cannot update the userspace address and we
+	 * get the lock or one of them succeeds in fixing it for us.
+	 */
+	if (ret && !argowner) {
+		ret = -EAGAIN;
+		goto handle_err;
+	}
 
-	goto retry;
+	if (!ret)
+		goto retry;
+
+	return ret;
 }
 
 static long futex_wait_restart(struct restart_block *restart);
@@ -1788,7 +1836,6 @@ static long futex_wait_restart(struct restart_block *restart);
  */
 static int fixup_owner(u32 __user *uaddr, struct futex_q *q, int locked)
 {
-	struct task_struct *owner;
 	int ret = 0;
 
 	if (locked) {
@@ -1806,27 +1853,7 @@ static int fixup_owner(u32 __user *uaddr, struct futex_q *q, int locked)
 	 * way back before we locked the hash bucket.
 	 */
 	if (q->pi_state->owner == current) {
-		/*
-		 * Try to get the rt_mutex now. This might fail as some other
-		 * task acquired the rt_mutex after we removed ourself from the
-		 * rt_mutex waiters list.
-		 */
-		if (rt_mutex_trylock(&q->pi_state->pi_mutex)) {
-			locked = 1;
-			goto out;
-		}
-
-		/*
-		 * pi_state is incorrect, some other task did a lock steal and
-		 * we returned due to timeout or signal without taking the
-		 * rt_mutex. Too late.
-		 */
-		raw_spin_lock(&q->pi_state->pi_mutex.wait_lock);
-		owner = rt_mutex_owner(&q->pi_state->pi_mutex);
-		if (!owner)
-			owner = rt_mutex_next_owner(&q->pi_state->pi_mutex);
-		raw_spin_unlock(&q->pi_state->pi_mutex.wait_lock);
-		ret = fixup_pi_state_owner(uaddr, q, owner);
+		ret = fixup_pi_state_owner(uaddr, q, NULL);
 		goto out;
 	}
 
--
2.26.2

