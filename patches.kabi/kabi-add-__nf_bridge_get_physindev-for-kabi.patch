-	int			physinif;
+	struct net_device	*physindev;
 
 	/* always valid & non-NULL from FORWARD on, for physdev match */
 	struct net_device	*physoutdev;
@@ -277,6 +277,9 @@ struct nf_bridge_info {
 		 */
 		char neigh_header[8];
 	};
+#ifndef __GENKSYMS__
+	int 			physinif;
+#endif
