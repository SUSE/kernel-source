 		physdev = nf_bridge_get_physoutdev(entry->skb);
--- a/net/netfilter/nfnetlink_log.c
+++ b/net/netfilter/nfnetlink_log.c
@@ -460,7 +460,7 @@ __build_packet_message(struct nfnl_log_n
