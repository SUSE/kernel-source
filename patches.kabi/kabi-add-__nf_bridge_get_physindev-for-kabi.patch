From: Fernando Fernandez Mancera <fmancera@suse.de>
Date: Wed, 11 Jun 2025 11:00:56 +0200
Subject: [PATCH] kabi: add __nf_bridge_get_physindev() for kabi
References: bsc#1224726,CVE-2024-35839
Patch-Mainline: never, kabi fix

nf_bridge_get_physindev() arguments changes as now it receives an additional
struct net. In addition, nf_log_dump_packet_common() must propagate struct net
too. For kABI compliance reasons, change the names to
__nf_bridge_get_physindev() and __nf_log_dump_packet_common(). The original
functions were restored too.

Signed-off-by: Fernando Fernandez Mancera <fmancera@suse.de>
---
 include/linux/netfilter_bridge.h           |    8 ++++++-
 include/net/netfilter/nf_log.h             |   10 +++++++--
 net/ipv4/netfilter/nf_log_arp.c            |    4 +--
 net/ipv4/netfilter/nf_log_ipv4.c           |    4 +--
 net/ipv4/netfilter/nf_reject_ipv4.c        |    2 -
 net/ipv6/netfilter/nf_log_ipv6.c           |    4 +--
 net/ipv6/netfilter/nf_reject_ipv6.c        |    2 -
 net/netfilter/ipset/ip_set_hash_netiface.c |    2 -
 net/netfilter/nf_log_common.c              |   31 +++++++++++++++++++++++++++--
 net/netfilter/nf_queue.c                   |    6 ++---
 net/netfilter/nfnetlink_log.c              |    2 -
 net/netfilter/xt_physdev.c                 |    2 -
 12 files changed, 58 insertions(+), 19 deletions(-)

--- a/include/linux/netfilter_bridge.h
+++ b/include/linux/netfilter_bridge.h
@@ -50,7 +50,13 @@ static inline int nf_bridge_get_physouti
 }
 
 static inline struct net_device *
-nf_bridge_get_physindev(const struct sk_buff *skb, struct net *net)
+nf_bridge_get_physindev(const struct sk_buff *skb)
+{
+	return skb->nf_bridge ? skb->nf_bridge->physindev : NULL;
+}
+
+static inline struct net_device *
+__nf_bridge_get_physindev(const struct sk_buff *skb, struct net *net)
 {
 	return skb->nf_bridge ? skb->nf_bridge->physindev : NULL;
 }
--- a/include/net/netfilter/nf_log.h
+++ b/include/net/netfilter/nf_log.h
@@ -111,8 +111,14 @@ void nf_log_dump_packet_common(struct nf
 			       const struct net_device *in,
 			       const struct net_device *out,
 			       const struct nf_loginfo *loginfo,
-			       const char *prefix,
-			       struct net *net);
+			       const char *prefix);
+void __nf_log_dump_packet_common(struct nf_log_buf *m, u_int8_t pf,
+				 unsigned int hooknum, const struct sk_buff *skb,
+				 const struct net_device *in,
+				 const struct net_device *out,
+				 const struct nf_loginfo *loginfo,
+				 const char *prefix,
+				 struct net *net);
 void nf_log_l2packet(struct net *net, u_int8_t pf,
 		     __be16 protocol,
 		     unsigned int hooknum,
--- a/net/ipv4/netfilter/nf_log_arp.c
+++ b/net/ipv4/netfilter/nf_log_arp.c
@@ -95,8 +95,8 @@ static void nf_log_arp_packet(struct net
 	if (!loginfo)
 		loginfo = &default_loginfo;
 
-	nf_log_dump_packet_common(m, pf, hooknum, skb, in, out, loginfo,
-				  prefix, net);
+	__nf_log_dump_packet_common(m, pf, hooknum, skb, in, out, loginfo,
+				    prefix, net);
 	dump_arp_packet(m, loginfo, skb, 0);
 
 	nf_log_buf_close(m);
--- a/net/ipv4/netfilter/nf_log_ipv4.c
+++ b/net/ipv4/netfilter/nf_log_ipv4.c
@@ -327,8 +327,8 @@ static void nf_log_ip_packet(struct net
 	if (!loginfo)
 		loginfo = &default_loginfo;
 
-	nf_log_dump_packet_common(m, pf, hooknum, skb, in,
-				  out, loginfo, prefix, net);
+	__nf_log_dump_packet_common(m, pf, hooknum, skb, in,
+				    out, loginfo, prefix, net);
 
 	if (in != NULL)
 		dump_ipv4_mac_header(m, loginfo, skb);
--- a/net/ipv4/netfilter/nf_reject_ipv4.c
+++ b/net/ipv4/netfilter/nf_reject_ipv4.c
@@ -148,7 +148,7 @@ void nf_send_reset(struct net *net, stru
 	if (oldskb->nf_bridge) {
 		struct ethhdr *oeth = eth_hdr(oldskb);
 
-		nskb->dev = nf_bridge_get_physindev(oldskb, net);
+		nskb->dev = __nf_bridge_get_physindev(oldskb, net);
 		niph->tot_len = htons(nskb->len);
 		ip_send_check(niph);
 		if (dev_hard_header(nskb, nskb->dev, ntohs(nskb->protocol),
--- a/net/ipv6/netfilter/nf_log_ipv6.c
+++ b/net/ipv6/netfilter/nf_log_ipv6.c
@@ -359,8 +359,8 @@ static void nf_log_ip6_packet(struct net
 	if (!loginfo)
 		loginfo = &default_loginfo;
 
-	nf_log_dump_packet_common(m, pf, hooknum, skb, in, out,
-				  loginfo, prefix, net);
+	__nf_log_dump_packet_common(m, pf, hooknum, skb, in, out,
+				    loginfo, prefix, net);
 
 	if (in != NULL)
 		dump_ipv6_mac_header(m, loginfo, skb);
--- a/net/ipv6/netfilter/nf_reject_ipv6.c
+++ b/net/ipv6/netfilter/nf_reject_ipv6.c
@@ -189,7 +189,7 @@ void nf_send_reset6(struct net *net, str
 	if (oldskb->nf_bridge) {
 		struct ethhdr *oeth = eth_hdr(oldskb);
 
-		nskb->dev = nf_bridge_get_physindev(oldskb, net);
+		nskb->dev = __nf_bridge_get_physindev(oldskb, net);
 		nskb->protocol = htons(ETH_P_IPV6);
 		ip6h->payload_len = htons(sizeof(struct tcphdr));
 		if (dev_hard_header(nskb, nskb->dev, ntohs(nskb->protocol),
--- a/net/netfilter/ipset/ip_set_hash_netiface.c
+++ b/net/netfilter/ipset/ip_set_hash_netiface.c
@@ -138,7 +138,7 @@ hash_netiface4_data_next(struct hash_net
 #if IS_ENABLED(CONFIG_BRIDGE_NETFILTER)
 static const char *get_physindev_name(const struct sk_buff *skb, struct net *net)
 {
-	struct net_device *dev = nf_bridge_get_physindev(skb, net);
+	struct net_device *dev = __nf_bridge_get_physindev(skb, net);
 
 	return dev ? dev->name : NULL;
 }
--- a/net/netfilter/nf_log_common.c
+++ b/net/netfilter/nf_log_common.c
@@ -153,6 +153,33 @@ nf_log_dump_packet_common(struct nf_log_
 			  unsigned int hooknum, const struct sk_buff *skb,
 			  const struct net_device *in,
 			  const struct net_device *out,
+			  const struct nf_loginfo *loginfo, const char *prefix)
+{
+	nf_log_buf_add(m, KERN_SOH "%c%sIN=%s OUT=%s ",
+	       '0' + loginfo->u.log.level, prefix,
+	       in ? in->name : "",
+	       out ? out->name : "");
+#if IS_ENABLED(CONFIG_BRIDGE_NETFILTER)
+	if (skb->nf_bridge) {
+		const struct net_device *physindev;
+		const struct net_device *physoutdev;
+
+		physindev = nf_bridge_get_physindev(skb);
+		if (physindev && in != physindev)
+			nf_log_buf_add(m, "PHYSIN=%s ", physindev->name);
+		physoutdev = nf_bridge_get_physoutdev(skb);
+		if (physoutdev && out != physoutdev)
+			nf_log_buf_add(m, "PHYSOUT=%s ", physoutdev->name);
+	}
+#endif
+}
+EXPORT_SYMBOL_GPL(nf_log_dump_packet_common);
+
+void
+__nf_log_dump_packet_common(struct nf_log_buf *m, u_int8_t pf,
+			  unsigned int hooknum, const struct sk_buff *skb,
+			  const struct net_device *in,
+			  const struct net_device *out,
 			  const struct nf_loginfo *loginfo, const char *prefix,
 			  struct net *net)
 {
@@ -165,7 +192,7 @@ nf_log_dump_packet_common(struct nf_log_
 		const struct net_device *physindev;
 		const struct net_device *physoutdev;
 
-		physindev = nf_bridge_get_physindev(skb, net);
+		physindev = __nf_bridge_get_physindev(skb, net);
 		if (physindev && in != physindev)
 			nf_log_buf_add(m, "PHYSIN=%s ", physindev->name);
 		physoutdev = nf_bridge_get_physoutdev(skb);
@@ -174,7 +201,7 @@ nf_log_dump_packet_common(struct nf_log_
 	}
 #endif
 }
-EXPORT_SYMBOL_GPL(nf_log_dump_packet_common);
+EXPORT_SYMBOL_GPL(__nf_log_dump_packet_common);
 
 /* bridge and netdev logging families share this code. */
 void nf_log_l2packet(struct net *net, u_int8_t pf,
