From 4dd153edf5a439bb938ec130d3c34c7e32623b15 Mon Sep 17 00:00:00 2001
From: Denis Kirjanov <denis.kirjanov@suse.com>
Date: Thu, 2 Feb 2023 13:46:51 +0300
Subject: [PATCH 2/2] net/l2tp: preserve kabi for session_create
Patch-mainline: Never (kABI fixup)
References: bsc#1108488 CVE-2018-9517

The patch adds a similar function pointer and puts
stubs for original session_create

Signed-off-by: Denis Kirjanov <denis.kirjanov@suse.com>
---
 net/l2tp/l2tp_core.h    | 5 ++++-
 net/l2tp/l2tp_eth.c     | 9 ++++++++-
 net/l2tp/l2tp_netlink.c | 2 +-
 net/l2tp/l2tp_ppp.c     | 9 ++++++++-
 4 files changed, 21 insertions(+), 4 deletions(-)

diff --git a/net/l2tp/l2tp_core.h b/net/l2tp/l2tp_core.h
index 1540bd2eda9e..1d7c0e3f099d 100644
--- a/net/l2tp/l2tp_core.h
+++ b/net/l2tp/l2tp_core.h
@@ -219,9 +219,12 @@ struct l2tp_tunnel {
 };
 
 struct l2tp_nl_cmd_ops {
-	int (*session_create)(struct net *net, struct l2tp_tunnel *tunnel,
+	int (*session_create)(struct net *net, u32 tunnel_id, u32 session_id, u32 peer_session_id, struct l2tp_session_cfg *cfg);
+#ifndef __GENKSYMS__
+	int (*__session_create)(struct net *net, struct l2tp_tunnel *tunnel,
 			      u32 session_id, u32 peer_session_id,
 			      struct l2tp_session_cfg *cfg);
+#endif
 	int (*session_delete)(struct l2tp_session *session);
 };
 
diff --git a/net/l2tp/l2tp_eth.c b/net/l2tp/l2tp_eth.c
index 98cf46b81dcf..5c802613dd3d 100644
--- a/net/l2tp/l2tp_eth.c
+++ b/net/l2tp/l2tp_eth.c
@@ -183,6 +183,12 @@ static void l2tp_eth_show(struct seq_fil
 }
 #endif
 
+static int __unused_session_create(struct net *net, u32 tunnel_id, u32 session_id,
+                                  u32 peer_session_id, struct l2tp_session_cfg *cfg)
+{
+       return 0;
+}
+
 static int l2tp_eth_create(struct net *net, struct l2tp_tunnel *tunnel,
                           u32 session_id, u32 peer_session_id,
                           struct l2tp_session_cfg *cfg)
@@ -307,7 +313,8 @@ static struct pernet_operations l2tp_eth_net_ops = {
 
 
 static const struct l2tp_nl_cmd_ops l2tp_eth_nl_cmd_ops = {
-	.session_create	= l2tp_eth_create,
+	.session_create = __unused_session_create, 
+	.__session_create	= l2tp_eth_create,
 	.session_delete	= l2tp_session_delete,
 };
 
diff --git a/net/l2tp/l2tp_netlink.c b/net/l2tp/l2tp_netlink.c
index 3211f2432eef..e18798985109 100644
--- a/net/l2tp/l2tp_netlink.c
+++ b/net/l2tp/l2tp_netlink.c
@@ -622,7 +622,7 @@ static int l2tp_nl_cmd_session_create(struct sk_buff *skb, struct genl_info *inf
 		break;
 	}
 
-	ret = l2tp_nl_cmd_ops[cfg.pw_type]->session_create(net, tunnel,
+	ret = l2tp_nl_cmd_ops[cfg.pw_type]->__session_create(net, tunnel,
 							   session_id,
 							   peer_session_id,
 							   &cfg);
diff --git a/net/l2tp/l2tp_ppp.c b/net/l2tp/l2tp_ppp.c
index 118b4be1963a..22a6abc261c8 100644
--- a/net/l2tp/l2tp_ppp.c
+++ b/net/l2tp/l2tp_ppp.c
@@ -803,6 +803,12 @@ static int pppol2tp_connect(struct socket *sock, struct sockaddr *uservaddr,
 
 #ifdef CONFIG_L2TP_V3
 
+static int __unused_session_create(struct net *net, u32 tunnel_id, u32 session_id,
+		                   u32 peer_session_id, struct l2tp_session_cfg *cfg)
+{
+	return 0;
+}
+
 /* Called when creating sessions via the netlink interface. */
 static int pppol2tp_session_create(struct net *net, struct l2tp_tunnel *tunnel,
 				   u32 session_id, u32 peer_session_id,
@@ -1771,7 +1771,8 @@ static const struct pppox_proto pppol2tp
 #ifdef CONFIG_L2TP_V3
 
 static const struct l2tp_nl_cmd_ops pppol2tp_nl_cmd_ops = {
-	.session_create	= pppol2tp_session_create,
+	.session_create	= __unused_session_create,
+	.__session_create = pppol2tp_session_create,
 	.session_delete	= pppol2tp_session_delete,
 };
 
-- 
2.16.4

