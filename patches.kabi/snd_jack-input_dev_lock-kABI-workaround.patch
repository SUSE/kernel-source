From: Takashi Iwai <tiwai@suse.de>
Subject: kABI workaround for snd_jack.input_dev_lock field
Patch-mainline: Never, kABI workaround
References: CVE-2022-49538 bsc#1238843

The recent fix added a new field input_dev_lock to struct snd_jack.
Move to the tail and wrap it for kABI compatibility.

Signed-off-by: Takashi Iwai <tiwai@suse.de>

---
 include/sound/jack.h |    4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

--- a/include/sound/jack.h
+++ b/include/sound/jack.h
@@ -77,7 +77,6 @@ struct snd_jack {
 	const char *id;
 #ifdef CONFIG_SND_JACK_INPUT_DEV
 	struct input_dev *input_dev;
-	struct mutex input_dev_lock;
 	int registered;
 	int type;
 	char name[100];
@@ -85,6 +84,9 @@ struct snd_jack {
 #endif /* CONFIG_SND_JACK_INPUT_DEV */
 	void *private_data;
 	void (*private_free)(struct snd_jack *);
+#ifndef __GENKSYMS__
+	struct mutex input_dev_lock;
+#endif
 };
 
 #ifdef CONFIG_SND_JACK
