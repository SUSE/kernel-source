From: Davide Benini <davide.benini@suse.com>
Date: Fri May  2 14:47:34 CEST 2025
Subject: kABI workaround for changeing the variable length type to size_t.
Patch-mainline: Never, kABI workaround
References: CVE-2022-49728 bsc#1239111

Signed-off-by: Davide Benini <davide.benini@suse.com>

---
 include/net/ipv6.h    |   16 ++++++++++++++--
 net/ipv6/ip6_output.c |   16 ++++++++++++++--
 2 files changed, 28 insertions(+), 4 deletions(-)

--- a/include/net/ipv6.h
+++ b/include/net/ipv6.h
@@ -834,7 +834,13 @@ int ip6_find_1stfragopt(struct sk_buff *
 int ip6_append_data(struct sock *sk,
 		    int getfrag(void *from, char *to, int offset, int len,
 				int odd, struct sk_buff *skb),
-		    void *from, size_t length, int transhdrlen,
+		    void *from,
+#ifndef __GENKSYMS__
+		    size_t length,
+#else
+		    int length,
+#endif
+		    int transhdrlen,
 		    struct ipcm6_cookie *ipc6, struct flowi6 *fl6,
 		    struct rt6_info *rt, unsigned int flags,
 		    const struct sockcm_cookie *sockc);
@@ -851,7 +857,13 @@ struct sk_buff *__ip6_make_skb(struct so
 struct sk_buff *ip6_make_skb(struct sock *sk,
 			     int getfrag(void *from, char *to, int offset,
 					 int len, int odd, struct sk_buff *skb),
-			     void *from, size_t length, int transhdrlen,
+			     void *from,
+#ifndef __GENKSYMS__
+			     size_t length,
+#else
+			     int length,
+#endif
+			     int transhdrlen,
 			     struct ipcm6_cookie *ipc6, struct flowi6 *fl6,
 			     struct rt6_info *rt, unsigned int flags,
 			     const struct sockcm_cookie *sockc);
--- a/net/ipv6/ip6_output.c
+++ b/net/ipv6/ip6_output.c
@@ -1565,7 +1565,13 @@ error:
 int ip6_append_data(struct sock *sk,
 		    int getfrag(void *from, char *to, int offset, int len,
 				int odd, struct sk_buff *skb),
-		    void *from, size_t length, int transhdrlen,
+		    void *from,
+#ifndef __GENKSYMS__
+		    size_t length,
+#else
+		    int length,
+#endif
+		    int transhdrlen,
 		    struct ipcm6_cookie *ipc6, struct flowi6 *fl6,
 		    struct rt6_info *rt, unsigned int flags,
 		    const struct sockcm_cookie *sockc)
@@ -1753,7 +1759,13 @@ EXPORT_SYMBOL_GPL(ip6_flush_pending_fram
 struct sk_buff *ip6_make_skb(struct sock *sk,
 			     int getfrag(void *from, char *to, int offset,
 					 int len, int odd, struct sk_buff *skb),
-			     void *from, size_t length, int transhdrlen,
+			     void *from,
+#ifndef __GENKSYMS__
+			     size_t length,
+#else
+			     int length,
+#endif
+			     int transhdrlen,
 			     struct ipcm6_cookie *ipc6, struct flowi6 *fl6,
 			     struct rt6_info *rt, unsigned int flags,
 			     const struct sockcm_cookie *sockc)
