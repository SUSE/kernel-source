From: Petr Pavlu <petr.pavlu@suse.com>
Date: Mon Mar 3 14:46:18 2025 +0100
Subject: kABI: Preserve TRACE_EVENT_FL values
Patch-mainline: Never, kABI fix
References: bsc#1232163

Preserve values of TRACE_EVENT_FL_* after the removal of
TRACE_EVENT_FL_WAS_ENABLED_BIT and TRACE_EVENT_FL_WAS_ENABLED.

Signed-off-by: Petr Pavlu <petr.pavlu@suse.com>
---
 include/linux/trace_events.h |    2 ++
 1 file changed, 2 insertions(+)

--- a/include/linux/trace_events.h
+++ b/include/linux/trace_events.h
@@ -209,6 +209,7 @@ enum {
 	TRACE_EVENT_FL_CAP_ANY_BIT,
 	TRACE_EVENT_FL_NO_SET_FILTER_BIT,
 	TRACE_EVENT_FL_IGNORE_ENABLE_BIT,
+	TRACE_EVENT_FL_UNUSED_BIT, // was TRACE_EVENT_FL_WAS_ENABLED_BIT
 	TRACE_EVENT_FL_TRACEPOINT_BIT,
 	TRACE_EVENT_FL_KPROBE_BIT,
 	TRACE_EVENT_FL_UPROBE_BIT,
@@ -229,6 +230,7 @@ enum {
 	TRACE_EVENT_FL_CAP_ANY		= (1 << TRACE_EVENT_FL_CAP_ANY_BIT),
 	TRACE_EVENT_FL_NO_SET_FILTER	= (1 << TRACE_EVENT_FL_NO_SET_FILTER_BIT),
 	TRACE_EVENT_FL_IGNORE_ENABLE	= (1 << TRACE_EVENT_FL_IGNORE_ENABLE_BIT),
+	TRACE_EVENT_FL_UNUSED	      	= (1 << TRACE_EVENT_FL_UNUSED_BIT), // was TRACE_EVENT_FL_WAS_ENABLED
 	TRACE_EVENT_FL_TRACEPOINT	= (1 << TRACE_EVENT_FL_TRACEPOINT_BIT),
 	TRACE_EVENT_FL_KPROBE		= (1 << TRACE_EVENT_FL_KPROBE_BIT),
 	TRACE_EVENT_FL_UPROBE		= (1 << TRACE_EVENT_FL_UPROBE_BIT),
