From 9bbf63b45f34d146ec1eebd3e43da0417ee27da7 Mon Sep 17 00:00:00 2001
From: Chun-Yi Lee <jlee@suse.com>
Date: Thu, 7 Nov 2024 19:02:16 +0800
Subject: [PATCH] driver core: kABI workaround for dev_groups in device_driver
Patch-mainline: Never, kABI workaround for SLE12-SP5 kernel
References: bsc#1232224 CVE-2024-49925

For 23b6904442d0 ("driver core: add dev_groups to all drivers")
backporting.

Signed-off-by: Chun-Yi Lee <jlee@suse.com>
---
 include/linux/device.h | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/include/linux/device.h b/include/linux/device.h
index b6c688981..4b6f040c9 100644
--- a/include/linux/device.h
+++ b/include/linux/device.h
@@ -291,11 +291,13 @@ struct device_driver {
 	int (*suspend) (struct device *dev, pm_message_t state);
 	int (*resume) (struct device *dev);
 	const struct attribute_group **groups;
-	const struct attribute_group **dev_groups;
 
 	const struct dev_pm_ops *pm;
 
 	struct driver_private *p;
+#ifndef __GENKSYMS__
+	const struct attribute_group **dev_groups;
+#endif
 };
 
 
-- 
2.35.3

