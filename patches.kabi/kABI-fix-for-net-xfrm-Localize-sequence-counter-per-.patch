From: Steffen Jaeckel <sjaeckel@suse.de>
Subject: kABI fix for net: xfrm: Localize sequence counter per network
 namespace
Patch-mainline: Never, kABI workaround
References: CVE-2024-57982 bsc#1237913

Upstream commit e88add19f681 ("net: xfrm: Localize sequence
counter per network namespace") introduced a new struct member
`xfrm_state_hash_generation`. Move that one to a hole, in order to
preserve kABI.

```
struct netns_xfrm {
[...]
        atomic_t                   flow_cache_genid;     /*   896     4 */

        /* XXX 4 bytes hole, try to pack */

        struct list_head           flow_cache_gc_list;   /*   904    16 */
[...]
```

Signed-off-by: Steffen Jaeckel <sjaeckel@suse.de>
---
 include/net/netns/xfrm.h | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/include/net/netns/xfrm.h b/include/net/netns/xfrm.h
index d57aebecc94b1..2f36ef27e9da2 100644
--- a/include/net/netns/xfrm.h
+++ b/include/net/netns/xfrm.h
@@ -71,7 +71,6 @@ struct netns_xfrm {
 	struct dst_ops		xfrm6_dst_ops;
 #endif
 	spinlock_t		xfrm_state_lock;
-	seqcount_t		xfrm_state_hash_generation;
 
 	spinlock_t xfrm_policy_lock;
 	struct mutex xfrm_cfg_mutex;
@@ -79,6 +78,9 @@ struct netns_xfrm {
 	/* flow cache part */
 	struct flow_cache	flow_cache_global;
 	atomic_t		flow_cache_genid;
+#ifndef __GENKSYMS__
+	seqcount_t		xfrm_state_hash_generation;
+#endif
 	struct list_head	flow_cache_gc_list;
 	atomic_t		flow_cache_gc_count;
 	spinlock_t		flow_cache_gc_lock;
-- 
2.49.0

