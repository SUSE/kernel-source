From 3db51604afb234f52bdeb0c7f411a273c98b88f4 Mon Sep 17 00:00:00 2001
From: Ales Novak <alnovak@suse.cz>
Date: Wed, 28 May 2025 12:35:27 +0200
Subject: [PATCH 2/2] kabi: hide owner from struct Qdisc
Patch-mainline: never, kabi
References: CVE-2024-27010, bsc#1223720
Signed-off-by: Ales Novak <alnovak@suse.cz>

Backport of upstream 0f022d32c3eca ("net/sched: Fix mirred deadlock on
device recursion") added new member "owner" into struct Qdisc - luckily
there are quite some holes due to cacheline aligning. Let's move it
there and mask hide it from kABI checker.
---
 include/net/sch_generic.h | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/include/net/sch_generic.h b/include/net/sch_generic.h
index d96c0e355b29d..5eac4c62c39a5 100644
--- a/include/net/sch_generic.h
+++ b/include/net/sch_generic.h
@@ -100,13 +100,15 @@ struct Qdisc {
 	struct gnet_stats_basic_packed bstats;
 	seqcount_t		running;
 	struct gnet_stats_queue	qstats;
-	int                     owner;
 	unsigned long		state;
 	struct Qdisc            *next_sched;
 	struct sk_buff_head	skb_bad_txq;
 	int			padded;
 	refcount_t		refcnt;
 
+#ifndef __GENKSYMS__
+	int                     owner;
+#endif
 	spinlock_t		busylock ____cacheline_aligned_in_smp;
 	spinlock_t		seqlock;
 
-- 
2.49.0

