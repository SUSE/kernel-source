From: Allen Pais <allen.pais@oracle.com>
Date: Wed, 18 Sep 2019 22:06:58 +0530
Subject: scsi: qla2xxx: fix a potential NULL pointer dereference
Patch-mainline: v5.4-rc5
Git-commit: 35a79a63517981a8aea395497c548776347deda8
References: bsc#1150457 CVE-2019-16233

alloc_workqueue is not checked for errors and as a result a potential
NULL dereference could occur.

Link: https://lore.kernel.org/r/1568824618-4366-1-git-send-email-allen.pais@oracle.com
Signed-off-by: Allen Pais <allen.pais@oracle.com>
Reviewed-by: Martin Wilck <mwilck@suse.com>
Acked-by: Himanshu Madhani <hmadhani@marvell.com>
Signed-off-by: Martin K. Petersen <martin.petersen@oracle.com>
[dwagner backport to v3.0]
Acked-by: Daniel Wagner <dwagner@suse.de>
---
 drivers/scsi/qla2xxx/qla_os.c |   11 +++++++++--
 1 file changed, 9 insertions(+), 2 deletions(-)

--- a/drivers/scsi/qla2xxx/qla_os.c
+++ b/drivers/scsi/qla2xxx/qla_os.c
@@ -414,6 +414,12 @@ static int qla25xx_setup_mode(struct scs
 			goto fail;
 		}
 		ha->wq = alloc_workqueue("qla2xxx_wq", WQ_MEM_RECLAIM, 1);
+		if (!ha->wq) {
+			ql_log(ql_log_warn, vha, 0x00e0,
+			    "Failed to create workqueue qla2xxx_wq.\n");
+			goto fail2;
+		}
+
 		vha->req = ha->req_q_map[req];
 		options |= BIT_1;
 		for (ques = 1; ques < ha->max_rsp_queues; ques++) {
@@ -421,7 +427,7 @@ static int qla25xx_setup_mode(struct scs
 			if (!ret) {
 				ql_log(ql_log_warn, vha, 0x00e8,
 				    "Failed to create response queue.\n");
-				goto fail2;
+				goto fail3;
 			}
 		}
 		ha->flags.cpu_affinity_enabled = 1;
@@ -435,9 +441,10 @@ static int qla25xx_setup_mode(struct scs
 		    ha->max_rsp_queues, ha->max_req_queues);
 	}
 	return 0;
+fail3:
+	destroy_workqueue(ha->wq);
 fail2:
 	qla25xx_delete_queues(vha);
-	destroy_workqueue(ha->wq);
 	ha->wq = NULL;
 fail:
 	ha->mqenable = 0;
