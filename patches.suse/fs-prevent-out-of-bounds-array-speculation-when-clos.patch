From 600224556c4971cbdf81c9595ddd576b0edd8d8e Mon Sep 17 00:00:00 2001
From: Theodore Ts'o <tytso@mit.edu>
Date: Mon, 6 Mar 2023 13:54:50 -0500
Subject: [PATCH] fs: prevent out-of-bounds array speculation when closing a
 file descriptor
Patch-mainline: v6.3-rc2
Git-commit: 609d54441493c99f21c1823dfd66fa7f4c512ff4
References: CVE-2023-53117 bsc#1242780

Google-Bug-Id: 114199369
Signed-off-by: Theodore Ts'o <tytso@mit.edu>
Signed-off-by: Al Viro <viro@zeniv.linux.org.uk>
[ddiss: rebase without commit 6319194ec57b0 ("Unify the primitives for
 file descriptor closing")]
[ddiss: rebase without commit 483ce1d4b8c3b ("take descriptor-related
 part of close() to file.c")]
Acked-by: David Disseldorp <ddiss@suse.de>
---
 fs/open.c | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/fs/open.c b/fs/open.c
index a97b846e3a4f6..2ebed08fb8de0 100644
--- a/fs/open.c
+++ b/fs/open.c
@@ -1139,6 +1139,8 @@ SYSCALL_DEFINE1(close, unsigned int, fd)
 	fdt = files_fdtable(files);
 	if (fd >= fdt->max_fds)
 		goto out_unlock;
+
+	fd = array_index_nospec(fd, fdt->max_fds);
 	filp = fdt->fd[fd];
 	if (!filp)
 		goto out_unlock;
-- 
2.50.1

