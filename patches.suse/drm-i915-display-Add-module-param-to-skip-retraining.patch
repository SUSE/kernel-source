From abc1a6ab8859cfec7a49a1409413918d78381e01 Mon Sep 17 00:00:00 2001
From: Patrik Jakobsson <patrik.r.jakobsson@gmail.com>
Date: Tue, 24 Mar 2026 13:08:51 +0100
Subject: [PATCH] drm/i915/display: Add module param to skip retraining of dp
 link
Patch-mainline: Never, workaround until upstream has a better solution
References: bsc#1253129

On the Nodka TPC6000-C152 there is an issue with the DP link requiring
retraining after a successful modeset. With the introduction of [1] we
end up in an endless loop of retraining the link. I suspect this is due
to a buggy HPD signal. Since the DMI strings are note populated properly
we cannot do a DMI quirk. Instead we add a module parameter to skip
rechecking the link after a successful modeset.

[1] 3b3be899fc81 drm/i915/dp: Recheck link state after modeset

Signed-off-by: Patrik Jakobsson <pjakobsson@suse.de>
---
 drivers/gpu/drm/i915/display/intel_display_params.c   |    5 +++++
 drivers/gpu/drm/i915/display/intel_display_params.h   |    1 +
 drivers/gpu/drm/i915/display/intel_dp_link_training.c |    3 ++-
 3 files changed, 8 insertions(+), 1 deletion(-)

--- a/drivers/gpu/drm/i915/display/intel_display_params.c
+++ b/drivers/gpu/drm/i915/display/intel_display_params.c
@@ -136,6 +136,11 @@ intel_display_param_named_unsafe(enable_
 	"(-1=use per-chip default, 0=disabled, 1=enabled, 2=match any register, 3=always locked) "
 	"Default: -1");
 
+intel_display_param_named(no_recheck_dp_link_state, bool, 0400,
+	"Enable quirk to skip rechecking DP link state after link training "
+	"(0=disabled, 1=enabled) "
+	"(Default: 0)");
+
 __maybe_unused
 static void _param_print_bool(struct drm_printer *p, const char *driver_name,
 			      const char *name, bool val)
--- a/drivers/gpu/drm/i915/display/intel_display_params.h
+++ b/drivers/gpu/drm/i915/display/intel_display_params.h
@@ -49,6 +49,7 @@ struct drm_printer;
 	param(bool, psr_safest_params, false, 0400) \
 	param(bool, enable_psr2_sel_fetch, true, 0400) \
 	param(int, enable_dmc_wl, -1, 0400) \
+	param(bool, no_recheck_dp_link_state, false, 0400) \
 
 #define MEMBER(T, member, ...) T member;
 struct intel_display_params {
--- a/drivers/gpu/drm/i915/display/intel_dp_link_training.c
+++ b/drivers/gpu/drm/i915/display/intel_dp_link_training.c
@@ -1145,7 +1145,8 @@ void intel_dp_stop_link_train(struct int
 	    intel_dp->link.seq_train_failures < MAX_SEQ_TRAIN_FAILURES) {
 		int delay_ms = intel_dp->link.seq_train_failures ? 0 : 2000;
 
-		intel_encoder_link_check_queue_work(encoder, delay_ms);
+		if (!display->params.no_recheck_dp_link_state)
+			intel_encoder_link_check_queue_work(encoder, delay_ms);
 	}
 }
 
