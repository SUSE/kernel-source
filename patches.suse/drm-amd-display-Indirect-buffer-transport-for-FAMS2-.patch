 drivers/gpu/drm/amd/display/dc/dc_dmub_srv.c  | 59 ++++++++++++++++++-
 drivers/gpu/drm/amd/display/dmub/dmub_srv.h   |  2 +
 .../gpu/drm/amd/display/dmub/src/dmub_srv.c   |  9 ++-
 4 files changed, 69 insertions(+), 2 deletions(-)

