+++ b/drivers/gpu/drm/amd/display/dc/dc_dmub_srv.c
@@ -1984,3 +1984,202 @@ void dc_dmub_srv_ips_query_residency_info(struct dc_dmub_srv *dc_dmub_srv, struc
 					       DM_DMUB_WAIT_TYPE_WAIT_WITH_REPLY))
 			output->histogram[i] = 0;
 }
