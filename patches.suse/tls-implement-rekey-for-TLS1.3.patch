 net/tls/tls_device.c |    2 
 net/tls/tls_main.c   |   46 ++++++++++++++++------
 net/tls/tls_sw.c     |  105 ++++++++++++++++++++++++++++++++++-----------------
 4 files changed, 108 insertions(+), 48 deletions(-)

--- a/net/tls/tls.h
