 			       const struct nf_loginfo *loginfo,
-			       const char *prefix);
+			       const char *prefix,
+			       struct net *net);
 void nf_log_l2packet(struct net *net, u_int8_t pf,
 		     __be16 protocol,
 		     unsigned int hooknum,
--- a/net/ipv4/netfilter/nf_log_arp.c
+++ b/net/ipv4/netfilter/nf_log_arp.c
