 	nf_log_buf_add(m, KERN_SOH "%c%sIN=%s OUT=%s ",
 	       '0' + loginfo->u.log.level, prefix,
@@ -164,7 +165,7 @@ nf_log_dump_packet_common(struct nf_log_
