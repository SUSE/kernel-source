+		physindev = nf_bridge_get_physindev(skb, net);
 		if (physindev && in != physindev)
 			nf_log_buf_add(m, "PHYSIN=%s ", physindev->name);
 		physoutdev = nf_bridge_get_physoutdev(skb);
