 		if (dev_hard_header(nskb, nskb->dev, ntohs(nskb->protocol),
--- a/net/netfilter/ipset/ip_set_hash_netiface.c
+++ b/net/netfilter/ipset/ip_set_hash_netiface.c
@@ -136,9 +136,9 @@ hash_netiface4_data_next(struct hash_net
