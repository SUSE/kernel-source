From bd504bcfec41a503b32054da5472904b404341a4 Mon Sep 17 00:00:00 2001
From: Mikulas Patocka <mpatocka@redhat.com>
Date: Tue, 9 Jan 2024 15:57:56 +0100
Subject: [PATCH] dm: limit the number of targets and parameter size area
Git-commit: bd504bcfec41a503b32054da5472904b404341a4
Patch-mainline: v6.8-rc3
References: bsc#1219827, bsc#1219146, CVE-2023-52429, CVE-2024-23851

The kvmalloc function fails with a warning if the size is larger than
INT_MAX. The warning was triggered by a syscall testing robot.

In order to avoid the warning, this commit limits the number of targets to
1048576 and the size of the parameter area to 1073741824.

(Coly Li: rebased for Linux v3.0 based SUSE kernel)

Signed-off-by: Mikulas Patocka <mpatocka@redhat.com>
Signed-off-by: Mike Snitzer <snitzer@kernel.org>
Signed-off-by: Coly Li <colyli@suse.de>
---
 drivers/md/dm-ioctl.c |    6 ++++--
 drivers/md/dm-table.c |    9 +++++++--
 drivers/md/dm.h       |    3 +++
 3 files changed, 14 insertions(+), 4 deletions(-)

--- a/drivers/md/dm-ioctl.c
+++ b/drivers/md/dm-ioctl.c
@@ -1505,11 +1505,13 @@ static int copy_params(struct dm_ioctl _
 {
 	struct dm_ioctl tmp, *dmi;
 	int secure_data;
+	const size_t minimum_data_size = sizeof(tmp) - sizeof(tmp.data);
 
-	if (copy_from_user(&tmp, user, sizeof(tmp) - sizeof(tmp.data)))
+	if (copy_from_user(&tmp, user, minimum_data_size))
 		return -EFAULT;
 
-	if (tmp.data_size < (sizeof(tmp) - sizeof(tmp.data)))
+	if (unlikely(tmp.data_size < minimum_data_size) ||
+	    unlikely(tmp.data_size > DM_MAX_TARGETS * DM_MAX_TARGET_PARAMS))
 		return -EINVAL;
 
 	secure_data = tmp.flags & DM_SECURE_DATA_FLAG;
--- a/drivers/md/dm-table.c
+++ b/drivers/md/dm-table.c
@@ -201,7 +201,12 @@ static int alloc_targets(struct dm_table
 int dm_table_create(struct dm_table **result, fmode_t mode,
 		    unsigned num_targets, struct mapped_device *md)
 {
-	struct dm_table *t = kzalloc(sizeof(*t), GFP_KERNEL);
+	struct dm_table *t;
+
+	if (num_targets > DM_MAX_TARGETS)
+		return -EOVERFLOW;
+
+	t = kzalloc(sizeof(*t), GFP_KERNEL);
 
 	if (!t)
 		return -ENOMEM;
@@ -219,7 +224,7 @@ int dm_table_create(struct dm_table **re
 	if (alloc_targets(t, num_targets)) {
 		kfree(t);
 		t = NULL;
-		return -ENOMEM;
+		return -EOVERFLOW;
 	}
 
 	t->mode = mode;
--- a/drivers/md/dm.h
+++ b/drivers/md/dm.h
@@ -29,6 +29,9 @@
 #define DM_TYPE_BIO_BASED	1
 #define DM_TYPE_REQUEST_BASED	2
 
+#define DM_MAX_TARGETS			1048576
+#define DM_MAX_TARGET_PARAMS		1024
+
 /*
  * List of devices that a metadevice uses and should open/close.
  */
