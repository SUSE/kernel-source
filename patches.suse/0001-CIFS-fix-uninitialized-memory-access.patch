From 2b8ad935ab2c3dfce427d7d2380183029d4b6e3b Mon Sep 17 00:00:00 2001
From: Aurelien Aptel <aaptel@suse.com>
Date: Tue, 9 Apr 2019 15:19:10 +0200
Subject: [PATCH] CIFS: fix uninitialized memory access
Patch-mainline: not yet, wip
References: bsc#1120326

in some codepaths written could be used without being initialized,
resulting in len being set to garbage which would in turn trigger the
BUG_ON() in iov_iter_advance().

Signed-off-by: Aurelien Aptel <aaptel@suse.com>
Acked-by: Aurelien Aptel <aaptel@suse.com>
Reviewed-by: Aurelien Aptel <aaptel@suse.com>

---
 fs/cifs/file.c | 1 +
 1 file changed, 1 insertion(+)

diff --git a/fs/cifs/file.c b/fs/cifs/file.c
index b98fc322bbdb..a5232a2cb7c3 100644
--- a/fs/cifs/file.c
+++ b/fs/cifs/file.c
@@ -1653,6 +1653,7 @@ cifs_iovec_write(struct kiocb *iocb, const struct iovec *iov,
 		npages = i;
 
 		do {
+			written = 0;
 			if (open_file->invalidHandle) {
 				rc = cifs_reopen_file(open_file, false);
 				if (rc != 0)
-- 
