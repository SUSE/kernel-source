From 63a2828b734589daaf2171f3d1fef19cbc3b083f Mon Sep 17 00:00:00 2001
From: Shrikanth Hegde <sshegde@linux.ibm.com>
Date: Tue, 14 Oct 2025 15:33:41 +0530
Subject: [PATCH] sched/deadline: Minor cleanup in select_task_rq_dl()

References: bsc#1234634 (Scheduler functional and performance backports SL-16.1)
Patch-mainline: v6.19-rc1
Git-commit: 65177ea9f64d7402a0b8028e0dbbd01e8a9d1b1d

In select_task_rq_dl, there is only one goto statement, there is no
need for it.

No functional changes.

Signed-off-by: Shrikanth Hegde <sshegde@linux.ibm.com>
Signed-off-by: Peter Zijlstra (Intel) <peterz@infradead.org>
Acked-by: Juri Lelli <juri.lelli@redhat.com>
Link: https://patch.msgid.link/20251014100342.978936-2-sshegde@linux.ibm.com
Signed-off-by: Mel Gorman <mgorman@suse.de>
---
 kernel/sched/deadline.c | 3 +--
 1 file changed, 1 insertion(+), 2 deletions(-)

diff --git a/kernel/sched/deadline.c b/kernel/sched/deadline.c
index c9a9851525d6..cdff2e429742 100644
--- a/kernel/sched/deadline.c
+++ b/kernel/sched/deadline.c
@@ -2463,7 +2463,7 @@ select_task_rq_dl(struct task_struct *p, int cpu, int flags)
 	struct rq *rq;
 
 	if (!(flags & WF_TTWU))
-		goto out;
+		return cpu;
 
 	rq = cpu_rq(cpu);
 
@@ -2501,7 +2501,6 @@ select_task_rq_dl(struct task_struct *p, int cpu, int flags)
 	}
 	rcu_read_unlock();
 
-out:
 	return cpu;
 }
 
