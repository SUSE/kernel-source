From: Hans Verkuil <hverkuil-cisco@xs4all.nl>
Date: Thu, 19 Oct 2023 08:58:49 +0200
Subject: [PATCH] media: pci: cx23885: check cx23885_vdev_init() return
Git-commit: 15126b916e39b0cb67026b0af3c014bfeb1f76b3
Patch-mainline: v6.9-rc1
References: CVE-2023-52918 bsc#1232047

cx23885_vdev_init() can return a NULL pointer, but that pointer
is used in the next line without a check.

Add a NULL pointer check and go to the error unwind if it is NULL.

Signed-off-by: Hans Verkuil <hverkuil-cisco@xs4all.nl>
Reported-by: Sicong Huang <huangsicong@iie.ac.cn>
Signed-off-by: David Sterba <dsterba@suse.com>
---
 drivers/media/pci/cx23885/cx23885-video.c |    8 ++++++++
 1 file changed, 8 insertions(+)

--- a/drivers/media/pci/cx23885/cx23885-video.c
+++ b/drivers/media/pci/cx23885/cx23885-video.c
@@ -1294,6 +1294,10 @@ int cx23885_video_register(struct cx2388
 	/* register Video device */
 	dev->video_dev = cx23885_vdev_init(dev, dev->pci,
 		&cx23885_video_template, "video");
+	if (!dev->video_dev) {
+		err = -ENOMEM;
+		goto fail_unreg;
+	}
 	dev->video_dev->queue = &dev->vb2_vidq;
 	err = video_register_device(dev->video_dev, VFL_TYPE_GRABBER,
 				    video_nr[dev->nr]);
@@ -1308,6 +1312,10 @@ int cx23885_video_register(struct cx2388
 	/* register VBI device */
 	dev->vbi_dev = cx23885_vdev_init(dev, dev->pci,
 		&cx23885_vbi_template, "vbi");
+	if (!dev->vbi_dev) {
+		err = -ENOMEM;
+		goto fail_unreg;
+	}
 	dev->vbi_dev->queue = &dev->vb2_vbiq;
 	err = video_register_device(dev->vbi_dev, VFL_TYPE_VBI,
 				    vbi_nr[dev->nr]);
