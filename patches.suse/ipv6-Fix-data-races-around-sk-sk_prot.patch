From 3d898c37b0b23fd65314bef6cc12cb8ffe7ebbfe Mon Sep 17 00:00:00 2001
From: Kuniyuki Iwashima <kuniyu@amazon.com>
Date: Thu, 6 Oct 2022 11:53:48 -0700
Subject: [PATCH 4/4] ipv6: Fix data races around sk->sk_prot.
Git-commit: 364f997b5cfe1db0d63a390fe7c801fa2b3115f6
Patch-mainline: v6.1-rc1
References: bsc#1204414 CVE-2022-3567

Commit 086d49058cd8 ("ipv6: annotate some data-races around sk->sk_prot")
fixed some data-races around sk->sk_prot but it was not enough.

Some functions in inet6_(stream|dgram)_ops still access sk->sk_prot
without lock_sock() or rtnl_lock(), so they need READ_ONCE() to avoid
load tearing.

Fixes: 1da177e4c3f4 ("Linux-2.6.12-rc2")
Signed-off-by: Kuniyuki Iwashima <kuniyu@amazon.com>
Signed-off-by: Jakub Kicinski <kuba@kernel.org>
Signed-off-by: Denis Kirjanov <denis.kirjanov@suse.com>
[ mkoutny: Adjust contexts for v3.0, s/READ_ONCE/ACCESS_ONCE/ ]
---
 net/core/sock.c          |    6 ++++--
 net/ipv4/af_inet.c       |   21 +++++++++++++++------
 net/ipv6/ipv6_sockglue.c |    4 ++--
 3 files changed, 21 insertions(+), 10 deletions(-)

--- a/net/core/sock.c
+++ b/net/core/sock.c
@@ -2198,7 +2198,8 @@ int sock_common_getsockopt(struct socket
 {
 	struct sock *sk = sock->sk;
 
-	return sk->sk_prot->getsockopt(sk, level, optname, optval, optlen);
+	/* IPV6_ADDRFORM can change sk->sk_prot under us. */
+	return ACCESS_ONCE(sk->sk_prot)->getsockopt(sk, level, optname, optval, optlen);
 }
 EXPORT_SYMBOL(sock_common_getsockopt);
 
@@ -2239,7 +2240,8 @@ int sock_common_setsockopt(struct socket
 {
 	struct sock *sk = sock->sk;
 
-	return sk->sk_prot->setsockopt(sk, level, optname, optval, optlen);
+	/* IPV6_ADDRFORM can change sk->sk_prot under us. */
+	return ACCESS_ONCE(sk->sk_prot)->setsockopt(sk, level, optname, optval, optlen);
 }
 EXPORT_SYMBOL(sock_common_setsockopt);
 
--- a/net/ipv4/af_inet.c
+++ b/net/ipv4/af_inet.c
@@ -551,15 +551,20 @@ int inet_dgram_connect(struct socket *so
 		       int addr_len, int flags)
 {
 	struct sock *sk = sock->sk;
+	const struct proto *prot;
 
 	if (addr_len < sizeof(uaddr->sa_family))
 		return -EINVAL;
+
+	/* IPV6_ADDRFORM can change sk->sk_prot under us. */
+	prot = ACCESS_ONCE(sk->sk_prot);
+
 	if (uaddr->sa_family == AF_UNSPEC)
-		return sk->sk_prot->disconnect(sk, flags);
+		return prot->disconnect(sk, flags);
 
 	if (!inet_sk(sk)->inet_num && inet_autobind(sk))
 		return -EAGAIN;
-	return sk->sk_prot->connect(sk, (struct sockaddr *)uaddr, addr_len);
+	return prot->connect(sk, (struct sockaddr *)uaddr, addr_len);
 }
 EXPORT_SYMBOL(inet_dgram_connect);
 
@@ -682,10 +687,11 @@ EXPORT_SYMBOL(inet_stream_connect);
 
 int inet_accept(struct socket *sock, struct socket *newsock, int flags)
 {
-	struct sock *sk1 = sock->sk;
+	struct sock *sk1 = sock->sk, *sk2;
 	int err = -EINVAL;
-	struct sock *sk2 = sk1->sk_prot->accept(sk1, flags, &err);
 
+	/* IPV6_ADDRFORM can change sk->sk_prot under us. */
+	sk2 = ACCESS_ONCE(sk1->sk_prot)->accept(sk1, flags, &err);
 	if (!sk2)
 		goto do_err;
 
@@ -766,12 +772,15 @@ ssize_t inet_sendpage(struct socket *soc
 		      size_t size, int flags)
 {
 	struct sock *sk = sock->sk;
+	const struct proto *prot;
 
 	if (unlikely(inet_send_prepare(sk)))
 		return -EAGAIN;
 
-	if (sk->sk_prot->sendpage)
-		return sk->sk_prot->sendpage(sk, page, offset, size, flags);
+	/* IPV6_ADDRFORM can change sk->sk_prot under us. */
+	prot = ACCESS_ONCE(sk->sk_prot);
+	if (prot->sendpage)
+		return prot->sendpage(sk, page, offset, size, flags);
 	return sock_no_sendpage(sock, page, offset, size, flags);
 }
 EXPORT_SYMBOL(inet_sendpage);
--- a/net/ipv6/ipv6_sockglue.c
+++ b/net/ipv6/ipv6_sockglue.c
@@ -205,7 +205,7 @@ static int do_ipv6_setsockopt(struct soc
 				sock_prot_inuse_add(net, &tcp_prot, 1);
 				local_bh_enable();
 
-				/* Paired with ACCESS_ONCE(sk->sk_prot) in net/ipv6/af_inet6.c */
+				/* Paired with ACCESS_ONCE(sk->sk_prot) in inet6_stream_ops */
 				ACCESS_ONCE(sk->sk_prot) = &tcp_prot;
 				/* Paired with ACCESS_ONCE() in tcp_(get|set)sockopt() */
 				ACCESS_ONCE(icsk->icsk_af_ops) = &ipv4_specific;
@@ -222,7 +222,7 @@ static int do_ipv6_setsockopt(struct soc
 				sock_prot_inuse_add(net, prot, 1);
 				local_bh_enable();
 
-				/* Paired with ACCESS_ONCE(sk->sk_prot) in net/ipv6/af_inet6.c */
+				/* Paired with ACCESS_ONCE(sk->sk_prot) in inet6_dgram_ops */
 				ACCESS_ONCE(sk->sk_prot) = prot;
 				sk->sk_socket->ops = &inet_dgram_ops;
 				sk->sk_family = PF_INET;
