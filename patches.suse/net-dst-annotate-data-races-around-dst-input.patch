From: Eric Dumazet <edumazet@google.com>
Date: Mon, 30 Jun 2025 12:19:28 +0000
Subject: net: dst: annotate data-races around dst->input
Patch-mainline: v6.17-rc1
Git-commit: f1c5fd34891a1c242885f48c2e4dc52df180f311
References: CVE-2025-40074 bsc#1252794

dst_dev_put() can overwrite dst->input while other
cpus might read this field (for instance from dst_input())

Add READ_ONCE()/WRITE_ONCE() annotations to suppress
potential issues.

We will likely need full RCU protection later.

Fixes: 4a6ce2b6f2ec ("net: introduce a new function dst_dev_put()")
Signed-off-by: Eric Dumazet <edumazet@google.com>
Reviewed-by: Kuniyuki Iwashima <kuniyu@google.com>
Link: https://patch.msgid.link/20250630121934.3399505-5-edumazet@google.com
Signed-off-by: Jakub Kicinski <kuba@kernel.org>
Acked-by: Michal Kubecek <mkubecek@suse.cz>

---
 include/net/dst.h | 5 ++++-
 net/core/dst.c    | 2 +-
 net/ipv4/route.c  | 4 ++--
 3 files changed, 7 insertions(+), 4 deletions(-)

--- a/include/net/dst.h
+++ b/include/net/dst.h
@@ -474,7 +474,10 @@ static inline int dst_output(struct net *net, struct sock *sk, struct sk_buff *s
 /* Input packet from network to transport.  */
 static inline int dst_input(struct sk_buff *skb)
 {
-	return skb_dst(skb)->input(skb);
+	int (*skb_input)(struct sk_buff *);
+
+	skb_input = READ_ONCE(skb_dst(skb)->input);
+	return skb_input(skb);
 }
 
 static inline struct dst_entry *dst_check(struct dst_entry *dst, u32 cookie)
--- a/net/core/dst.c
+++ b/net/core/dst.c
@@ -162,7 +162,7 @@ void dst_dev_put(struct dst_entry *dst)
 	WRITE_ONCE(dst->obsolete, DST_OBSOLETE_DEAD);
 	if (dst->ops->ifdown)
 		dst->ops->ifdown(dst, dev, true);
-	dst->input = dst_discard;
+	WRITE_ONCE(dst->input, dst_discard);
 	dst->output = dst_discard_out;
 	dst->dev = dev_net(dst->dev)->loopback_dev;
 	dev_hold(dst->dev);
--- a/net/ipv4/route.c
+++ b/net/ipv4/route.c
@@ -1728,8 +1728,8 @@ static void set_lwt_redirect(struct rtable *rth)
 	}
 
 	if (lwtunnel_input_redirect(rth->dst.lwtstate)) {
-		rth->dst.lwtstate->orig_input = rth->dst.input;
-		rth->dst.input = lwtunnel_input;
+		rth->dst.lwtstate->orig_input = READ_ONCE(rth->dst.input);
+		WRITE_ONCE(rth->dst.input, lwtunnel_input);
 	}
 }
 
