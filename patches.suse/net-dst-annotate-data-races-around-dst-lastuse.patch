From: Eric Dumazet <edumazet@google.com>
Date: Mon, 30 Jun 2025 12:19:27 +0000
Subject: net: dst: annotate data-races around dst->lastuse
Patch-mainline: v6.17-rc1
Git-commit: 8f2b2282d04a5d5bcbec22f91572bb6803cfc771
References: CVE-2025-40074 bsc#1252794

(dst_entry)->lastuse is read and written locklessly,
add corresponding annotations.

Signed-off-by: Eric Dumazet <edumazet@google.com>
Reviewed-by: Kuniyuki Iwashima <kuniyu@google.com>
Link: https://patch.msgid.link/20250630121934.3399505-4-edumazet@google.com
Signed-off-by: Jakub Kicinski <kuba@kernel.org>
Acked-by: Michal Kubecek <mkubecek@suse.cz>

---
 include/net/dst.h    | 4 ++--
 net/core/rtnetlink.c | 3 ++-
 net/ipv6/route.c     | 2 +-
 3 files changed, 5 insertions(+), 4 deletions(-)

--- a/include/net/dst.h
+++ b/include/net/dst.h
@@ -258,13 +258,13 @@ static inline void dst_use(struct dst_entry *dst, unsigned long time)
 {
 	dst_hold(dst);
 	dst->__use++;
-	dst->lastuse = time;
+	WRITE_ONCE(dst->lastuse, time);
 }
 
 static inline void dst_use_noref(struct dst_entry *dst, unsigned long time)
 {
 	dst->__use++;
-	dst->lastuse = time;
+	WRITE_ONCE(dst->lastuse, time);
 }
 
 static inline struct dst_entry *dst_clone(struct dst_entry *dst)
--- a/net/core/rtnetlink.c
+++ b/net/core/rtnetlink.c
@@ -743,12 +743,13 @@ int rtnl_put_cacheinfo(struct sk_buff *skb, struct dst_entry *dst, u32 id,
 		       long expires, u32 error)
 {
 	struct rta_cacheinfo ci = {
-		.rta_lastuse = jiffies_delta_to_clock_t(jiffies - dst->lastuse),
+		.rta_lastuse = jiffies_delta_to_clock_t(jiffies - READ_ONCE(dst->lastuse)),
 		.rta_used = dst->__use,
 		.rta_clntref = atomic_read(&(dst->__refcnt)),
 		.rta_error = error,
 		.rta_id =  id,
 	};
+	unsigned long delta;
 
 	if (expires) {
 		unsigned long clock;
--- a/net/ipv6/route.c
+++ b/net/ipv6/route.c
@@ -1143,7 +1143,7 @@ struct rt6_info *ip6_pol_route(struct net *net, struct fib6_table *table,
 
 		struct rt6_info *pcpu_rt;
 
-		rt->dst.lastuse = jiffies;
+		WRITE_ONCE(rt->dst.lastuse, jiffies);
 		rt->dst.__use++;
 		pcpu_rt = rt6_get_pcpu_route(rt);
 
