From: Ming Lei <ming.lei@redhat.com>
Date: Fri, 16 Jun 2023 21:23:54 +0800
Subject: blk-mq: fix NULL dereference on q->elevator in blk_mq_elv_switch_none
Git-commit: 245165658e1c9f95c0fecfe02b9b1ebd30a1198a
Patch-mainline: v6.5-rc1
References: CVE-2023-53292 bsc#1250163

After grabbing q->sysfs_lock, q->elevator may become NULL because of
elevator switch.

Fix the NULL dereference on q->elevator by checking it with lock.

Reported-by: Guangwu Zhang <guazhang@redhat.com>
Signed-off-by: Ming Lei <ming.lei@redhat.com>
Link: https://lore.kernel.org/r/20230616132354.415109-1-ming.lei@redhat.com
Signed-off-by: Jens Axboe <axboe@kernel.dk>
[lduncan: hunk 3 applied by hand; Also required commit
 245165658e1c9f95c0fecfe02b9b1ebd30a1198a]
Acked-by: Lee Duncan <lduncan@suse.com>
---
 block/blk-mq.c |   10 +++++++---
 1 file changed, 7 insertions(+), 3 deletions(-)

--- a/block/blk-mq.c
+++ b/block/blk-mq.c
@@ -3010,9 +3010,6 @@ static bool blk_mq_elv_switch_none(struc
 {
 	struct blk_mq_qe_pair *qe;
 
-	if (!q->elevator)
-		return true;
-
 	qe = kmalloc(sizeof(*qe), GFP_NOIO | __GFP_NOWARN | __GFP_NORETRY);
 	if (!qe)
 		return false;
@@ -3020,6 +3017,12 @@ static bool blk_mq_elv_switch_none(struc
 	/* q->elevator needs protection from ->sysfs_lock */
 	mutex_lock(&q->sysfs_lock);
 
+	/* the check has to be done with holding sysfs_lock */
+	if (!q->elevator) {
+		kfree(qe);
+		goto unlock;
+	}
+
 	INIT_LIST_HEAD(&qe->node);
 	qe->q = q;
 	qe->type = q->elevator->type;
@@ -3034,6 +3037,7 @@ static bool blk_mq_elv_switch_none(struc
 	 */
 	__module_get(qe->type->elevator_owner);
 	elevator_switch_mq(q, NULL);
+unlock:
 	mutex_unlock(&q->sysfs_lock);
 
 	return true;
