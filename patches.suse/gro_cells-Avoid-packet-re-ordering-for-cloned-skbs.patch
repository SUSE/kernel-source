From dba96609f9354464c8e94295682a6ea0e0e4a2db Mon Sep 17 00:00:00 2001
From: Thomas Bogendoerfer <tbogendoerfer@suse.de>
Date: Wed, 29 Jan 2025 10:41:22 +0100
Subject: gro_cells: Avoid packet re-ordering for cloned skbs
Patch-mainline: Never, upstream not happy, but needed for customer
References: bsc#1226323

gro_cells_receive() passes a cloned skb directly up the stack and
could cause re-ordering against segments still in GRO. To avoid
this take care of cloned skbs during gro processing by flushing
GRO queues.

Fixes: c9e6bc644e55 ("net: add gro_cells infrastructure")
Signed-off-by: Thomas Bogendoerfer <tbogendoerfer@suse.de>
---
 net/core/gro_cells.c   |    2 +-
 net/ipv4/tcp_offload.c |    6 ++++++
 net/ipv4/udp_offload.c |    5 +++++
 net/ipv6/udp_offload.c |    5 +++++
 4 files changed, 17 insertions(+), 1 deletion(-)

--- a/net/core/gro_cells.c
+++ b/net/core/gro_cells.c
@@ -18,7 +18,7 @@ int gro_cells_receive(struct gro_cells *
 	if (unlikely(!(dev->flags & IFF_UP)))
 		goto drop;
 
-	if (!gcells->cells || skb_cloned(skb) || netif_elide_gro(dev)) {
+	if (!gcells->cells || netif_elide_gro(dev)) {
 		res = netif_rx(skb);
 		goto unlock;
 	}
--- a/net/ipv4/tcp_offload.c
+++ b/net/ipv4/tcp_offload.c
@@ -230,6 +230,12 @@ struct sk_buff *tcp_gro_receive(struct l
 	goto out_check_final;
 
 found:
+	if (unlikely(skb_cloned(skb))) {
+		NAPI_GRO_CB(skb)->flush |= 1;
+		NAPI_GRO_CB(skb)->same_flow = 0;
+		return p;
+	}
+
 	/* Include the IP ID check below from the inner most IP hdr */
 	flush = NAPI_GRO_CB(p)->flush;
 	flush |= (__force int)(flags & TCP_FLAG_CWR);
--- a/net/ipv4/udp_offload.c
+++ b/net/ipv4/udp_offload.c
@@ -414,6 +414,11 @@ struct sk_buff *udp4_gro_receive(struct
 {
 	struct udphdr *uh = udp_gro_udphdr(skb);
 
+	if (unlikely(skb_cloned(skb))) {
+		NAPI_GRO_CB(skb)->same_flow = 0;
+		goto flush;
+	}
+
 	if (unlikely(!uh))
 		goto flush;
 
--- a/net/ipv6/udp_offload.c
+++ b/net/ipv6/udp_offload.c
@@ -120,6 +120,11 @@ struct sk_buff *udp6_gro_receive(struct
 {
 	struct udphdr *uh = udp_gro_udphdr(skb);
 
+	if (unlikely(skb_cloned(skb))) {
+		NAPI_GRO_CB(skb)->same_flow = 0;
+		goto flush;
+	}
+
 	if (unlikely(!uh))
 		goto flush;
 
