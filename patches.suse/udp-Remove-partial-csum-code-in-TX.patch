 		return -EMSGSIZE;
@@ -1144,8 +1132,6 @@ int udp_sendmsg(struct sock *sk, struct
 	if (msg->msg_flags & MSG_OOB) /* Mirror BSD error message compatibility */
 		return -EOPNOTSUPP;
 
