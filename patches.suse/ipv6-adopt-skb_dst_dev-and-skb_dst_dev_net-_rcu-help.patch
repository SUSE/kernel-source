 	if (net_xmit_eval(err) == 0) {
--- a/net/ipv6/netfilter.c
+++ b/net/ipv6/netfilter.c
@@ -59,7 +59,7 @@ int ip6_route_me_harder(struct net *net, struct sk_buff *skb)
 #endif
 
