 }
 
 #else /* !CONFIG_CGROUP_SCHED: */
@@ -2189,7 +2190,7 @@ static inline void __set_task_cpu(struct task_struct *p, unsigned int cpu)
 	smp_wmb();
 	WRITE_ONCE(task_thread_info(p)->cpu, cpu);
 	p->wake_cpu = cpu;
-#endif
