From: Joerg Roedel <jroedel@suse.de>
Date: Tue, 25 Feb 2020 15:29:38 +0100
Subject: [PATCH] kaiser: Fix for 32bit KAISER implementations
References: bsc#1157344
Patch-mainline: No, SLE11-SP4-LTSS-only KAISER fix

- Corret the SHARED_KERNEL_PMD setting when running with
  kaiser enabled
- Allocate machine-kexec page-table with correct size

Signed-off-by: Joerg Roedel <jroedel@suse.de>
---
 arch/x86/include/asm/pgtable-3level_types.h | 2 +-
 arch/x86/kernel/machine_kexec_32.c          | 7 ++++++-
 2 files changed, 7 insertions(+), 2 deletions(-)

--- a/arch/x86/include/asm/pgtable-3level_types.h
+++ b/arch/x86/include/asm/pgtable-3level_types.h
@@ -19,7 +19,7 @@ typedef union {
 #endif	/* !__ASSEMBLY__ */
 
 #ifdef CONFIG_PARAVIRT_MMU
-#define SHARED_KERNEL_PMD	(pv_info.shared_kernel_pmd)
+#define SHARED_KERNEL_PMD	(pv_info.shared_kernel_pmd && !kaiser_enabled)
 #else
 #define SHARED_KERNEL_PMD	1
 #endif
--- a/arch/x86/kernel/machine_kexec_32.c
+++ b/arch/x86/kernel/machine_kexec_32.c
@@ -87,7 +87,12 @@ static void machine_kexec_free_page_tabl
 
 static int machine_kexec_alloc_page_tables(struct kimage *image)
 {
-	image->arch.pgd = (pgd_t *)get_zeroed_page(GFP_KERNEL);
+	int gfp_order = 0;
+
+	if (kaiser_enabled)
+		gfp_order = 1;
+
+	image->arch.pgd = (pgd_t *)__get_free_pages(GFP_KERNEL | __GFP_ZERO, gfp_order);
 #ifdef CONFIG_X86_PAE
 	image->arch.pmd0 = (pmd_t *)get_zeroed_page(GFP_KERNEL);
 	image->arch.pmd1 = (pmd_t *)get_zeroed_page(GFP_KERNEL);
